# ==============================================
# Suhird (सुहृद्) - Configuration
# ==============================================
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# --- Database ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5433
POSTGRES_DB=suhird
POSTGRES_USER=suhird_user
POSTGRES_PASSWORD=CHANGE_ME_strong_password_here

# --- Qdrant Vector DB ---
QDRANT_HOST=localhost
QDRANT_PORT=6335

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6380

# --- MemPalace Preference Learning ---
MEMPALACE_URL=http://localhost:8001

# --- Ollama Embeddings ---
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=nomic-embed-text

# --- Photo Storage ---
# Options: "local" or "minio"
STORAGE_TYPE=local
LOCAL_STORAGE_PATH=./photos

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_generate_a_real_secret
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32)[:32])"
ENCRYPTION_KEY=CHANGE_ME_32_character_key_here

# --- OpenClaw Gateway ---
OPENCLAW_GATEWAY_URL=http://localhost:18789
OPENCLAW_GATEWAY_TOKEN=your_openclaw_gateway_token

# --- Suhird API Token ---
# This token is used by OpenClaw to authenticate requests to Suhird
# Must match the apiKey in openclaw.json suhird-bot provider
SUHIRD_API_TOKEN=CHANGE_ME_generate_a_token

# --- Known Numbers ---
# Comma-separated phone numbers that should NOT receive matchmaking
# These are handled by OpenClaw's normal assistant
KNOWN_PERSONAL_NUMBERS=+91852*****97,+91831*****24
KNOWN_TEAM_NUMBERS=+91620*****67,+91898*****59,+91763*****70,+91898*****01
